# ===========================================
# Printer Management System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# MySQL Database
# ===========================================
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=printer_management
MYSQL_USER=printer_admin
MYSQL_PASSWORD=your_secure_password_here

# ===========================================
# JWT Authentication
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars_here_1234567890
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here

# ===========================================
# URLs & Ports
# ===========================================
# Change to your server IP for production
FRONTEND_URL=https://YOUR_SERVER_IP:10443
VITE_API_URL=/api

# Nginx ports (change if 80/443 are in use)
HTTP_PORT=8080
HTTPS_PORT=10443

# ===========================================
# SSL Configuration
# ===========================================
# Domain for SSL certificate (use localhost for development)
SSL_DOMAIN=localhost

# ===========================================
# SMTP Email (Optional - for notifications)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Printer System <noreply@yourdomain.com>

# ===========================================
# Timezone
# ===========================================
# Common timezones: America/Chicago, America/New_York, America/Los_Angeles, America/Bogota
TZ=America/Chicago

# ===========================================
# Driver Pack (lite/common/full)
# ===========================================
# lite (~500MB): HP, Kyocera, Epson, Brother - IPP Everywhere
# common (~1.5GB): + Canon, Ricoh, Lexmark, Samsung
# full (~3GB): All CUPS drivers for legacy printers
DRIVER_SET=lite
