# ===========================================
# Printer Management System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# MySQL Database
# ===========================================
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=printer_management
MYSQL_USER=printer_admin
MYSQL_PASSWORD=your_secure_password_here

# ===========================================
# JWT Authentication
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars_here_1234567890
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here

# ===========================================
# URLs
# ===========================================
FRONTEND_URL=https://localhost
VITE_API_URL=/api

# ===========================================
# SSL Configuration
# ===========================================
# Domain for SSL certificate (use localhost for development)
SSL_DOMAIN=localhost

# ===========================================
# SMTP Email (Optional - for notifications)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Printer System <noreply@yourdomain.com>

# ===========================================
# Timezone
# ===========================================
TZ=America/Bogota

# ===========================================
# CUPS Configuration (Host paths)
# ===========================================
# These are the default paths on Ubuntu
# CUPS_SOCKET=/var/run/cups/cups.sock
# CUPS_CONFIG=/etc/cups
